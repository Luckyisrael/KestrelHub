@using System.Net.Http.Json
@inject HttpClient Http
@inject ISnackbar Snackbar

<MudDialog Style="background: #12141a; color: #e4e6eb;">
    <DialogContent>
        <MudTextField @bind-Value="_key" Label="Key" Variant="Variant.Outlined" Margin="Margin.Dense"
                      Placeholder="MY_API_KEY" Class="mb-4" />
        <MudTextField @bind-Value="_value" Label="Value" Variant="Variant.Outlined" Margin="Margin.Dense"
                      InputType="@InputType.Password" Class="mb-4" />
        <MudSelect T="string" @bind-Value="_environment" Label="Environment" Variant="Variant.Outlined" Margin="Margin.Dense">
            <MudSelectItem Value="@("Production")">Production</MudSelectItem>
            <MudSelectItem Value="@("Staging")">Staging</MudSelectItem>
            <MudSelectItem Value="@("Development")">Development</MudSelectItem>
        </MudSelect>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Variant="Variant.Outlined" Style="color: #8a8d93;">Cancel</MudButton>
        <MudButton OnClick="Submit" Variant="Variant.Filled" Color="Color.Primary"
                   Disabled="@_submitting" Style="color: #000; font-weight: 600;">
            @(_submitting ? "Saving..." : "Save")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;

    private string _key = "";
    private string _value = "";
    private string _environment = "Production";
    private bool _submitting;

    private async Task Submit()
    {
        if (string.IsNullOrWhiteSpace(_key) || string.IsNullOrWhiteSpace(_value))
        {
            Snackbar.Add("Key and Value are required", Severity.Warning);
            return;
        }

        _submitting = true;
        try
        {
            var response = await Http.PostAsJsonAsync("/api/secrets", new
            {
                DeploymentId = (Guid?)null,
                Key = _key,
                Value = _value,
                Environment = _environment
            });

            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add("Secret saved", Severity.Success);
                MudDialog.Close(DialogResult.Ok(true));
            }
            else
            {
                Snackbar.Add("Failed to save secret", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        _submitting = false;
    }

    private void Cancel() => MudDialog.Cancel();
}
