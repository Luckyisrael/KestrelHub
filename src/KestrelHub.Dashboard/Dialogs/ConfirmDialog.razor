@using MudBlazor

<MudDialog Style="background: #12141a; color: #e4e6eb;">
    <DialogContent>
        <MudText Typo="Typo.body1" Style="color: #e4e6eb;">@ContentText</MudText>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Variant="Variant.Outlined" Style="color: #8a8d93;">Cancel</MudButton>
        <MudButton OnClick="Confirm" Variant="Variant.Filled" Color="@Color" Style="color: #000; font-weight: 600;">
            @ButtonText
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public string ContentText { get; set; } = "";
    [Parameter] public string ButtonText { get; set; } = "Confirm";
    [Parameter] public Color Color { get; set; } = Color.Primary;

    private void Confirm() => MudDialog.Close(DialogResult.Ok(true));
    private void Cancel() => MudDialog.Cancel();
}
