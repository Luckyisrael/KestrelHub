@page "/deployments/{Id:guid}"
@attribute [Authorize]
@using System.Net.Http.Json
@using System.Text.Json
@using KestrelHub.Shared.Models
@using KestrelHub.Shared.Enums
@using Microsoft.AspNetCore.Authorization
@inject HttpClient Http
@inject NavigationManager Navigation

<PageTitle>@(_deployment?.Name ?? "Deployment") — KestrelHub</PageTitle>

<div style="padding: 24px;">
    @if (_loading)
    {
        <div style="display: flex; justify-content: center; padding: 48px;">
            <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
        </div>
    }
    else if (_deployment is null)
    {
        <MudAlert Severity="Severity.Error" Variant="Variant.Outlined">Deployment not found</MudAlert>
    }
    else
    {
        <!-- Header -->
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px;">
            <div>
                <MudButton Variant="Variant.Text" Href="/deployments"
                           Style="color: #8a8d93; padding: 0; margin-bottom: 8px; text-transform: none;">
                    <MudIcon Icon="@Icons.Material.Filled.ArrowBack" Size="Size.Small" Style="margin-right: 4px;" />
                    Back to deployments
                </MudButton>
                <MudText Typo="Typo.h4" Style="color: #e4e6eb;">@_deployment.Name</MudText>
                <div style="display: flex; gap: 16px; align-items: center; margin-top: 8px;">
                    <StatusChip Status="@_deployment.Status" />
                    @if (!string.IsNullOrEmpty(_deployment.AssignedDomain))
                    {
                        <MudText Typo="Typo.body2" Style="color: #7c3aed;">
                            @_deployment.AssignedDomain
                        </MudText>
                    }
                </div>
            </div>
        </div>

        <!-- Tabs -->
        <MudTabs Elevation="0" Rounded="false" Color="Color.Primary"
                 Style="background: #12141a; border-radius: 12px; border: 1px solid #1e2028;">
            <MudTabPanel Text="Logs" Style="color: #e4e6eb;">
                <div style="background: #0a0c0f; border-radius: 0 0 12px 12px; padding: 16px; font-family: 'JetBrains Mono', monospace; font-size: 13px; color: #8a8d93; min-height: 300px; max-height: 500px; overflow-y: auto;">
                    @if (_logs.Count == 0)
                    {
                        <div style="color: #8a8d93; padding: 32px; text-align: center;">
                            No logs yet. Logs will appear here during deployment.
                        </div>
                    }
                    else
                    {
                        @foreach (var log in _logs)
                        {
                            <div style="margin-bottom: 2px; color: @(log.IsError ? "#ef4444" : "#8a8d93");">
                                <span style="color: #1e2028;">[@log.Timestamp.ToString("HH:mm:ss")]</span>
                                @log.Message
                            </div>
                        }
                    }
                </div>
            </MudTabPanel>
            <MudTabPanel Text="Settings">
                <div style="padding: 24px; color: #8a8d93;">
                    <MudText Typo="Typo.body2">Appsettings editor coming in Step 3.5</MudText>
                </div>
            </MudTabPanel>
            <MudTabPanel Text="Secrets">
                <div style="padding: 24px; color: #8a8d93;">
                    <MudText Typo="Typo.body2">Secret vault coming in Step 3.4</MudText>
                </div>
            </MudTabPanel>
        </MudTabs>
    }
</div>

@code {
    [Parameter] public Guid Id { get; set; }

    private AppDeployment? _deployment;
    private List<DeploymentLog> _logs = [];
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var response = await Http.GetFromJsonAsync<JsonElement>($"/api/deployments/{Id}");
            if (response.ValueKind == JsonValueKind.Object)
            {
                _deployment = new AppDeployment
                {
                    Id = Id,
                    Name = response.GetProperty("name").GetString() ?? "",
                    GitUrl = response.GetProperty("gitUrl").GetString() ?? "",
                    Branch = response.GetProperty("branch").GetString() ?? "",
                    Status = Enum.Parse<DeploymentStatus>(response.GetProperty("status").GetString() ?? "Pending"),
                    AssignedDomain = response.TryGetProperty("assignedDomain", out var d) ? d.GetString() : null,
                    CreatedAt = response.GetProperty("createdAt").GetDateTime(),
                    UpdatedAt = response.GetProperty("updatedAt").GetDateTime()
                };

                if (response.TryGetProperty("logs", out var logsElement))
                {
                    _logs = JsonSerializer.Deserialize<List<DeploymentLog>>(logsElement.GetRawText(), new JsonSerializerOptions { PropertyNameCaseInsensitive = true }) ?? [];
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading deployment: {ex.Message}");
        }
        _loading = false;
    }
}
