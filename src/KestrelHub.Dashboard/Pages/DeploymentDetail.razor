@page "/deployments/{Id:guid}"
@attribute [Authorize]
@using System.Net.Http.Json
@using System.Text.Json
@using KestrelHub.Shared.Models
@using KestrelHub.Shared.Enums
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.SignalR.Client
@inject HttpClient Http
@inject KestrelHub.Dashboard.Services.JwtAuthStateProvider AuthStateProvider
@inject NavigationManager Navigation
@implements IAsyncDisposable

<PageTitle>@(_deployment?.Name ?? "Deployment") — KestrelHub</PageTitle>

<div style="padding: 24px;">
    @if (_loading)
    {
        <div style="display: flex; justify-content: center; padding: 48px;">
            <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
        </div>
    }
    else if (_deployment is null)
    {
        <MudAlert Severity="Severity.Error" Variant="Variant.Outlined">Deployment not found</MudAlert>
    }
    else
    {
        <!-- Header -->
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px;">
            <div>
                <MudButton Variant="Variant.Text" Href="/deployments"
                           Style="color: #8a8d93; padding: 0; margin-bottom: 8px; text-transform: none;">
                    <MudIcon Icon="@Icons.Material.Filled.ArrowBack" Size="Size.Small" Style="margin-right: 4px;" />
                    Back to deployments
                </MudButton>
                <MudText Typo="Typo.h4" Style="color: #e4e6eb;">@_deployment.Name</MudText>
                <div style="display: flex; gap: 16px; align-items: center; margin-top: 8px;">
                    <StatusChip Status="@_currentStatus" />
                    @if (!string.IsNullOrEmpty(_deployment.AssignedDomain))
                    {
                        <MudText Typo="Typo.body2" Style="color: #7c3aed;">
                            @_deployment.AssignedDomain
                        </MudText>
                    }
                    @if (_hubConnected)
                    {
                        <span style="width: 8px; height: 8px; border-radius: 50%; background: #22c55e;" title="Live"></span>
                    }
                </div>
            </div>
        </div>

        <!-- Tabs -->
        <MudTabs Elevation="0" Rounded="false" Color="Color.Primary"
                 Style="background: #12141a; border-radius: 12px; border: 1px solid #1e2028;">
            <MudTabPanel Text="Logs" Style="color: #e4e6eb;">
                <div id="log-terminal" style="background: #0a0c0f; border-radius: 0 0 12px 12px; padding: 16px; font-family: 'JetBrains Mono', monospace; font-size: 13px; color: #8a8d93; min-height: 400px; max-height: 600px; overflow-y: auto;">
                    @if (_logs.Count == 0)
                    {
                        <div style="color: #8a8d93; padding: 32px; text-align: center;">
                            No logs yet. Logs will appear here during deployment.
                        </div>
                    }
                    else
                    {
                        @foreach (var log in _logs)
                        {
                            <div style="margin-bottom: 4px; line-height: 1.6;">
                                <span style="color: #1e2028; font-size: 11px;">@log.Timestamp.ToLocalTime().ToString("HH:mm:ss")</span>
                                <span style="color: @(log.IsError ? "#ef4444" : "#8a8d93");">@log.Message</span>
                            </div>
                        }
                    }
                </div>
            </MudTabPanel>
            <MudTabPanel Text="Settings">
                <div style="padding: 24px; color: #8a8d93;">
                    <MudText Typo="Typo.body2">Appsettings editor coming in Step 3.5</MudText>
                </div>
            </MudTabPanel>
            <MudTabPanel Text="Secrets">
                <div style="padding: 24px; color: #8a8d93;">
                    <MudText Typo="Typo.body2">Secret vault coming in Step 3.4</MudText>
                </div>
            </MudTabPanel>
        </MudTabs>
    }
</div>

@code {
    [Parameter] public Guid Id { get; set; }

    private AppDeployment? _deployment;
    private DeploymentStatus _currentStatus;
    private List<DeploymentLog> _logs = [];
    private bool _loading = true;
    private HubConnection? _hubConnection;
    private bool _hubConnected;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var response = await Http.GetFromJsonAsync<JsonElement>($"/api/deployments/{Id}");
            if (response.ValueKind == JsonValueKind.Object)
            {
                _deployment = new AppDeployment
                {
                    Id = Id,
                    Name = response.GetProperty("name").GetString() ?? "",
                    GitUrl = response.GetProperty("gitUrl").GetString() ?? "",
                    Branch = response.GetProperty("branch").GetString() ?? "",
                    Status = Enum.Parse<DeploymentStatus>(response.GetProperty("status").GetString() ?? "Pending"),
                    AssignedDomain = response.TryGetProperty("assignedDomain", out var d) ? d.GetString() : null,
                    CreatedAt = response.GetProperty("createdAt").GetDateTime(),
                    UpdatedAt = response.GetProperty("updatedAt").GetDateTime()
                };
                _currentStatus = _deployment.Status;

                if (response.TryGetProperty("logs", out var logsElement))
                {
                    _logs = JsonSerializer.Deserialize<List<DeploymentLog>>(logsElement.GetRawText(),
                        new JsonSerializerOptions { PropertyNameCaseInsensitive = true }) ?? [];
                }
            }

            await ConnectToSignalR();
        }
        catch { }
        _loading = false;
    }

    private async Task ConnectToSignalR()
    {
        var token = AuthStateProvider.AccessToken;

        _hubConnection = new HubConnectionBuilder()
            .WithUrl(new Uri("http://localhost:5001/hubs/deployments"), options =>
            {
                if (!string.IsNullOrEmpty(token))
                    options.AccessTokenProvider = () => Task.FromResult(token);
            })
            .WithAutomaticReconnect()
            .Build();

        _hubConnection.On<Guid, string, bool>("ReceiveLog", (deploymentId, message, isError) =>
        {
            if (deploymentId == Id)
            {
                _logs.Add(new DeploymentLog
                {
                    Id = Guid.NewGuid(),
                    DeploymentId = deploymentId,
                    Timestamp = DateTime.UtcNow,
                    Message = message,
                    IsError = isError
                });
                InvokeAsync(StateHasChanged);
            }
        });

        _hubConnection.On<Guid, string>("StatusChanged", (deploymentId, newStatus) =>
        {
            if (deploymentId == Id)
            {
                _currentStatus = Enum.Parse<DeploymentStatus>(newStatus);
                InvokeAsync(StateHasChanged);
            }
        });

        try
        {
            await _hubConnection.StartAsync();
            await _hubConnection.InvokeAsync("JoinDeployment", Id);
            _hubConnected = true;
        }
        catch
        {
            _hubConnected = false;
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_hubConnection is not null)
        {
            try
            {
                await _hubConnection.InvokeAsync("LeaveDeployment", Id);
                await _hubConnection.DisposeAsync();
            }
            catch { }
        }
    }
}
