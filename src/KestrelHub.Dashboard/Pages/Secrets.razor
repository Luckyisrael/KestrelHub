@page "/secrets"
@attribute [Authorize]
@using System.Net.Http.Json
@using System.Text.Json
@using KestrelHub.Dashboard.Dialogs
@using KestrelHub.Shared.Models
@using Microsoft.AspNetCore.Authorization
@inject HttpClient Http
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<PageTitle>Secrets — KestrelHub</PageTitle>

<div style="padding: 24px;">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px;">
        <div>
            <MudText Typo="Typo.h4" Style="color: #e4e6eb;">Secret Vault</MudText>
            <MudText Typo="Typo.body2" Style="color: #8a8d93; margin-top: 4px;">
                AES-256-GCM encrypted environment variables
            </MudText>
        </div>
        <AuthorizeView Roles="Admin,Developer">
            <Authorized>
                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           OnClick="@OpenCreateDialog" Style="color: #000; font-weight: 600;">
                    <MudIcon Icon="@Icons.Material.Filled.Add" Size="Size.Small" Style="margin-right: 6px;" />
                    Add Secret
                </MudButton>
            </Authorized>
        </AuthorizeView>
    </div>

    @if (_loading)
    {
        <div style="display: flex; justify-content: center; padding: 48px;">
            <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
        </div>
    }
    else if (_secrets.Count == 0)
    {
        <div style="text-align: center; padding: 64px 24px; background: #12141a; border-radius: 12px; border: 1px solid #1e2028;">
            <MudIcon Icon="@Icons.Material.Filled.Key" Style="font-size: 48px; color: #8a8d93;" />
            <MudText Typo="Typo.h6" Style="color: #e4e6eb; margin-top: 16px;">No secrets yet</MudText>
            <MudText Typo="Typo.body2" Style="color: #8a8d93; margin-top: 8px;">
                Add encrypted environment variables for your deployments.
            </MudText>
        </div>
    }
    else
    {
        <div style="background: #12141a; border-radius: 12px; border: 1px solid #1e2028; overflow: hidden;">
            <table style="width: 100%; border-collapse: collapse;">
                <thead>
                    <tr style="border-bottom: 1px solid #1e2028;">
                        <th style="padding: 12px 16px; text-align: left; color: #8a8d93; font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px;">Key</th>
                        <th style="padding: 12px 16px; text-align: left; color: #8a8d93; font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px;">Value</th>
                        <th style="padding: 12px 16px; text-align: left; color: #8a8d93; font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px;">Environment</th>
                        <th style="padding: 12px 16px; text-align: left; color: #8a8d93; font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px;">Created</th>
                        <th style="padding: 12px 16px; text-align: right; color: #8a8d93; font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var secret in _secrets)
                    {
                        <tr style="border-bottom: 1px solid #1e2028;">
                            <td style="padding: 12px 16px; color: #00d4ff; font-family: monospace; font-size: 13px;">@secret.Key</td>
                            <td style="padding: 12px 16px; color: #8a8d93; font-family: monospace; font-size: 13px;">
                                @if (_revealed.ContainsKey(secret.Id))
                                {
                                    <span style="color: #e4e6eb;">@_revealed[secret.Id]</span>
                                }
                                else
                                {
                                    <span>••••••••</span>
                                }
                            </td>
                            <td style="padding: 12px 16px;">
                                <span style="display: inline-block; padding: 2px 10px; border-radius: 12px; font-size: 12px; font-weight: 500;
                                    background: @(secret.Environment == "Production" ? "rgba(239, 68, 68, 0.15)" : "rgba(34, 197, 94, 0.15)");
                                    color: @(secret.Environment == "Production" ? "#ef4444" : "#22c55e");">
                                    @secret.Environment
                                </span>
                            </td>
                            <td style="padding: 12px 16px; color: #8a8d93; font-size: 13px;">@secret.CreatedAt.ToString("MMM dd, HH:mm")</td>
                            <td style="padding: 12px 16px; text-align: right;">
                                <MudIconButton Icon="@Icons.Material.Filled.Visibility" Size="Size.Small"
                                               OnClick="@(() => RevealValue(secret.Id))"
                                               Style="color: #8a8d93; margin-right: 4px;" Title="Reveal" />
                                <MudIconButton Icon="@Icons.Material.Filled.History" Size="Size.Small"
                                               OnClick="@(() => ShowAuditLog(secret.Id))"
                                               Style="color: #8a8d93; margin-right: 4px;" Title="Audit Log" />
                                <AuthorizeView Roles="Admin,Developer">
                                    <Authorized Context="auth">
                                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                                       OnClick="@(() => DeleteSecret(secret.Id))"
                                                       Style="color: #ef4444;" Title="Delete" />
                                    </Authorized>
                                </AuthorizeView>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@code {
    private List<Secret> _secrets = [];
    private Dictionary<Guid, string> _revealed = new();
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadSecrets();
    }

    private async Task LoadSecrets()
    {
        _loading = true;
        try
        {
            var response = await Http.GetFromJsonAsync<List<Secret>>("/api/secrets");
            _secrets = response ?? [];
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load secrets: {ex.Message}", Severity.Error);
        }
        _loading = false;
    }

    private async Task RevealValue(Guid id)
    {
        if (_revealed.ContainsKey(id))
        {
            _revealed.Remove(id);
            return;
        }

        try
        {
            var response = await Http.GetFromJsonAsync<JsonElement>($"/api/secrets/{id}/value");
            var value = response.GetProperty("value").GetString() ?? "";
            _revealed[id] = value;
        }
        catch
        {
            Snackbar.Add("Failed to reveal secret", Severity.Error);
        }
    }

    private async Task ShowAuditLog(Guid id)
    {
        try
        {
            var logs = await Http.GetFromJsonAsync<List<SecretAuditLog>>($"/api/secrets/{id}/audit");
            var message = logs is not null && logs.Count > 0
                ? string.Join("\n", logs.Select(l => $"[{l.Timestamp:HH:mm:ss}] {l.Action} by {l.ActorEmail}"))
                : "No audit entries";

            var parameters = new DialogParameters<ConfirmDialog>
            {
                { x => x.ContentText, message },
                { x => x.ButtonText, "Close" },
                { x => x.Color, Color.Default }
            };
            await DialogService.ShowAsync<ConfirmDialog>("Audit Log", parameters);
        }
        catch
        {
            Snackbar.Add("Failed to load audit log", Severity.Error);
        }
    }

    private async Task DeleteSecret(Guid id)
    {
        try
        {
            await Http.DeleteAsync($"/api/secrets/{id}");
            _secrets.RemoveAll(s => s.Id == id);
            Snackbar.Add("Secret deleted", Severity.Warning);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to delete: {ex.Message}", Severity.Error);
        }
    }

    private async Task OpenCreateDialog()
    {
        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<CreateSecretDialog>("Add Secret", options);
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            await LoadSecrets();
        }
    }
}
