@page "/deployments"
@attribute [Authorize]
@using System.Net.Http.Json
@using System.Text.Json
@using KestrelHub.Dashboard.Dialogs
@using KestrelHub.Shared.Models
@using KestrelHub.Shared.Enums
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@inject HttpClient Http
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Deployments — KestrelHub</PageTitle>

<div style="padding: 24px;">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px;">
        <div>
            <MudText Typo="Typo.h4" Style="color: #e4e6eb;">Deployments</MudText>
            <MudText Typo="Typo.body2" Style="color: #8a8d93; margin-top: 4px;">
                Manage your deployed applications
            </MudText>
        </div>
        <AuthorizeView Roles="Admin,Developer">
            <Authorized>
                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           OnClick="@OpenCreateDialog" Style="color: #000; font-weight: 600;">
                    <MudIcon Icon="@Icons.Material.Filled.Add" Size="Size.Small" Style="margin-right: 6px;" />
                    New Deployment
                </MudButton>
            </Authorized>
        </AuthorizeView>
    </div>

    @if (_loading)
    {
        <div style="display: flex; justify-content: center; padding: 48px;">
            <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
        </div>
    }
    else if (_deployments.Count == 0)
    {
        <div style="text-align: center; padding: 64px 24px; background: #12141a; border-radius: 12px; border: 1px solid #1e2028;">
            <MudIcon Icon="@Icons.Material.Filled.CloudOff" Style="font-size: 48px; color: #8a8d93;" />
            <MudText Typo="Typo.h6" Style="color: #e4e6eb; margin-top: 16px;">No deployments yet</MudText>
            <MudText Typo="Typo.body2" Style="color: #8a8d93; margin-top: 8px;">
                Create your first deployment to get started.
            </MudText>
        </div>
    }
    else
    {
        <div style="background: #12141a; border-radius: 12px; border: 1px solid #1e2028; overflow: hidden;">
            <MudDataGrid Items="@_deployments" Dense="true" Hover="true" Style="background: transparent;">
                <Columns>
                    <PropertyColumn Property="x => x.Name" Title="Name" Style="color: #e4e6eb;">
                        <CellTemplate>
                            <a href="/deployments/@context.Item.Id"
                               style="color: #00d4ff; text-decoration: none; font-weight: 500;">
                                @context.Item.Name
                            </a>
                        </CellTemplate>
                    </PropertyColumn>
                    <PropertyColumn Property="x => x.GitUrl" Title="Repository" Style="color: #8a8d93;">
                        <CellTemplate>
                            <MudText Typo="Typo.body2" Style="color: #8a8d93; max-width: 200px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                                @context.Item.GitUrl
                            </MudText>
                        </CellTemplate>
                    </PropertyColumn>
                    <PropertyColumn Property="x => x.Branch" Title="Branch" Style="color: #8a8d93;" />
                    <TemplateColumn Title="Status">
                        <CellTemplate>
                            <StatusChip Status="@context.Item.Status" />
                        </CellTemplate>
                    </TemplateColumn>
                    <PropertyColumn Property="x => x.AssignedDomain" Title="Domain" Style="color: #8a8d93;">
                        <CellTemplate>
                            @if (!string.IsNullOrEmpty(context.Item.AssignedDomain))
                            {
                                <MudText Typo="Typo.body2" Style="color: #7c3aed;">@context.Item.AssignedDomain</MudText>
                            }
                            else
                            {
                                <MudText Typo="Typo.body2" Style="color: #8a8d93;">—</MudText>
                            }
                        </CellTemplate>
                    </PropertyColumn>
                    <TemplateColumn Title="Created">
                        <CellTemplate>
                            <MudText Typo="Typo.body2" Style="color: #8a8d93;">
                                @context.Item.CreatedAt.ToString("MMM dd, HH:mm")
                            </MudText>
                        </CellTemplate>
                    </TemplateColumn>
                    <TemplateColumn Title="Actions" Sortable="false">
                        <CellTemplate>
                            <div style="display: flex; gap: 4px;">
                                <AuthorizeView Roles="Admin,Developer" Context="auth">
                                    <Authorized>
                                        @if (context.Item.Status == DeploymentStatus.Running)
                                        {
                                            <MudIconButton Icon="@Icons.Material.Filled.Stop" Size="Size.Small"
                                                           OnClick="@(() => StopDeployment(context.Item.Id))"
                                                           Style="color: #f59e0b;" Title="Stop" />
                                        }
                                    </Authorized>
                                </AuthorizeView>
                                <AuthorizeView Roles="Admin" Context="auth">
                                    <Authorized>
                                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                                       OnClick="@(() => DeleteDeployment(context.Item.Id))"
                                                       Style="color: #ef4444;" Title="Delete" />
                                    </Authorized>
                                </AuthorizeView>
                            </div>
                        </CellTemplate>
                    </TemplateColumn>
                </Columns>
            </MudDataGrid>
        </div>
    }
</div>

@code {
    private List<AppDeployment> _deployments = [];
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadDeployments();
    }

    private async Task LoadDeployments()
    {
        _loading = true;
        try
        {
            var response = await Http.GetFromJsonAsync<List<AppDeployment>>("/api/deployments");
            _deployments = response ?? [];
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load deployments: {ex.Message}", Severity.Error);
        }
        _loading = false;
    }

    private async Task OpenCreateDialog()
    {
        var options = new DialogOptions
        {
            CloseOnEscapeKey = true,
            MaxWidth = MaxWidth.Small,
            FullWidth = true
        };

        var dialog = await DialogService.ShowAsync<CreateDeploymentDialog>("New Deployment", options);
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            await LoadDeployments();
        }
    }

    private async Task StopDeployment(Guid id)
    {
        var parameters = new DialogParameters<ConfirmDialog>
        {
            { x => x.ContentText, "Are you sure you want to stop this deployment?" },
            { x => x.ButtonText, "Stop" },
            { x => x.Color, Color.Warning }
        };

        var dialog = await DialogService.ShowAsync<ConfirmDialog>("Stop Deployment", parameters);
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            try
            {
                await Http.PostAsync($"/api/deployments/{id}/stop", null);
                Snackbar.Add("Deployment stopped", Severity.Info);
                await LoadDeployments();
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Failed to stop: {ex.Message}", Severity.Error);
            }
        }
    }

    private async Task DeleteDeployment(Guid id)
    {
        var parameters = new DialogParameters<ConfirmDialog>
        {
            { x => x.ContentText, "This will permanently delete the deployment and its container." },
            { x => x.ButtonText, "Delete" },
            { x => x.Color, Color.Error }
        };

        var dialog = await DialogService.ShowAsync<ConfirmDialog>("Delete Deployment", parameters);
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            try
            {
                await Http.DeleteAsync($"/api/deployments/{id}");
                Snackbar.Add("Deployment deleted", Severity.Warning);
                _deployments.RemoveAll(d => d.Id == id);
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Failed to delete: {ex.Message}", Severity.Error);
            }
        }
    }
}
