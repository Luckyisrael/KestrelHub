@page "/settings/users"
@attribute [Authorize(Roles = "Admin")]
@using System.Net.Http.Json
@using System.Text.Json
@using KestrelHub.Dashboard.Dialogs
@using Microsoft.AspNetCore.Authorization
@inject HttpClient Http
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<PageTitle>User Management — KestrelHub</PageTitle>

<div style="padding: 24px;">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px;">
        <div>
            <MudText Typo="Typo.h4" Style="color: #e4e6eb;">User Management</MudText>
            <MudText Typo="Typo.body2" Style="color: #8a8d93; margin-top: 4px;">
                Manage users, roles, and invitations
            </MudText>
        </div>
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   OnClick="@ShowInviteDialog" Style="color: #000; font-weight: 600;">
            <MudIcon Icon="@Icons.Material.Filled.PersonAdd" Size="Size.Small" Style="margin-right: 6px;" />
            Invite User
        </MudButton>
    </div>

    @if (_loading)
    {
        <div style="display: flex; justify-content: center; padding: 48px;">
            <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
        </div>
    }
    else
    {
        <div style="background: #12141a; border-radius: 12px; border: 1px solid #1e2028; overflow: hidden;">
            <table style="width: 100%; border-collapse: collapse;">
                <thead>
                    <tr style="border-bottom: 1px solid #1e2028;">
                        <th style="padding: 12px 16px; text-align: left; color: #8a8d93; font-size: 12px; font-weight: 600; text-transform: uppercase;">User</th>
                        <th style="padding: 12px 16px; text-align: left; color: #8a8d93; font-size: 12px; font-weight: 600; text-transform: uppercase;">Role</th>
                        <th style="padding: 12px 16px; text-align: left; color: #8a8d93; font-size: 12px; font-weight: 600; text-transform: uppercase;">Status</th>
                        <th style="padding: 12px 16px; text-align: left; color: #8a8d93; font-size: 12px; font-weight: 600; text-transform: uppercase;">Last Login</th>
                        <th style="padding: 12px 16px; text-align: right; color: #8a8d93; font-size: 12px; font-weight: 600; text-transform: uppercase;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in _users)
                    {
                        <tr style="border-bottom: 1px solid #1e2028;">
                            <td style="padding: 12px 16px;">
                                <MudText Typo="Typo.body2" Style="color: #e4e6eb; font-weight: 500;">@user.DisplayName</MudText>
                                <MudText Typo="Typo.caption" Style="color: #8a8d93;">@user.Email</MudText>
                            </td>
                            <td style="padding: 12px 16px;">
                                <MudSelect T="string" Value="@user.Role" ValueChanged="@(v => ChangeRole(user.Id, v))"
                                           Variant="Variant.Outlined" Dense="true" Style="width: 140px;"
                                           Disabled="@(user.IsSelf)">
                                    <MudSelectItem Value="@("Admin")">Admin</MudSelectItem>
                                    <MudSelectItem Value="@("Developer")">Developer</MudSelectItem>
                                    <MudSelectItem Value="@("Viewer")">Viewer</MudSelectItem>
                                </MudSelect>
                            </td>
                            <td style="padding: 12px 16px;">
                                <span style="display: inline-block; padding: 2px 10px; border-radius: 12px; font-size: 12px;
                                    background: @(user.IsActive ? "rgba(34, 197, 94, 0.15)" : "rgba(239, 68, 68, 0.15)");
                                    color: @(user.IsActive ? "#22c55e" : "#ef4444");">
                                    @(user.IsActive ? "Active" : "Inactive")
                                </span>
                            </td>
                            <td style="padding: 12px 16px; color: #8a8d93; font-size: 13px;">
                                @(user.LastLoginAt?.ToString("MMM dd, HH:mm") ?? "Never")
                            </td>
                            <td style="padding: 12px 16px; text-align: right;">
                                @if (!user.IsSelf)
                                {
                                    <MudIconButton Icon="@(user.IsActive ? Icons.Material.Filled.Block : Icons.Material.Filled.CheckCircle)"
                                                   Size="Size.Small"
                                                   OnClick="@(() => ToggleActive(user.Id, !user.IsActive))"
                                                   Style="@ToggleStyle(user.IsActive)"
                                                   Title="@(user.IsActive ? "Deactivate" : "Activate")" />
                                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                                   OnClick="@(() => DeleteUser(user.Id))"
                                                   Style="color: #ef4444;" Title="Delete" />
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@code {
    private List<UserViewModel> _users = [];
    private bool _loading = true;
    private string _currentUserId = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadUsers();
    }

    private async Task LoadUsers()
    {
        _loading = true;
        try
        {
            var response = await Http.GetFromJsonAsync<List<JsonElement>>("/api/users");
            if (response is not null)
            {
                _users = response.Select(u => new UserViewModel
                {
                    Id = u.GetProperty("id").GetString() ?? "",
                    Email = u.GetProperty("email").GetString() ?? "",
                    DisplayName = u.GetProperty("displayName").GetString() ?? "",
                    IsActive = u.GetProperty("isActive").GetBoolean(),
                    CreatedAt = u.GetProperty("createdAt").GetDateTime(),
                    LastLoginAt = u.TryGetProperty("lastLoginAt", out var ll) && ll.ValueKind != JsonValueKind.Null ? ll.GetDateTime() : null,
                    Role = u.GetProperty("roles").EnumerateArray().FirstOrDefault().GetString() ?? "Viewer"
                }).ToList();
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load users: {ex.Message}", Severity.Error);
        }
        _loading = false;
    }

    private async Task ShowInviteDialog()
    {
        var parameters = new DialogParameters<InviteUserDialog>();
        var dialog = await DialogService.ShowAsync<InviteUserDialog>("Invite User", new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true });
        var result = await dialog.Result;
        if (!result.Canceled) await LoadUsers();
    }

    private async Task ChangeRole(string userId, string newRole)
    {
        try
        {
            await Http.PutAsJsonAsync($"/api/users/{userId}", new { Role = newRole });
            Snackbar.Add("Role updated", Severity.Success);
            await LoadUsers();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed: {ex.Message}", Severity.Error);
        }
    }

    private async Task ToggleActive(string userId, bool isActive)
    {
        try
        {
            await Http.PutAsJsonAsync($"/api/users/{userId}", new { IsActive = isActive });
            Snackbar.Add(isActive ? "User activated" : "User deactivated", Severity.Info);
            await LoadUsers();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed: {ex.Message}", Severity.Error);
        }
    }

    private async Task DeleteUser(string userId)
    {
        var parameters = new DialogParameters<ConfirmDialog>
        {
            { x => x.ContentText, "This action cannot be undone." },
            { x => x.ButtonText, "Delete" },
            { x => x.Color, Color.Error }
        };
        var dialog = await DialogService.ShowAsync<ConfirmDialog>("Delete User", parameters);
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            try
            {
                await Http.DeleteAsync($"/api/users/{userId}");
                Snackbar.Add("User deleted", Severity.Warning);
                _users.RemoveAll(u => u.Id == userId);
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Failed: {ex.Message}", Severity.Error);
            }
        }
    }

    private string ToggleStyle(bool isActive) => isActive
        ? "color: #f59e0b; margin-right: 4px;"
        : "color: #22c55e; margin-right: 4px;";

    private class UserViewModel
    {
        public string Id { get; set; } = "";
        public string Email { get; set; } = "";
        public string DisplayName { get; set; } = "";
        public bool IsActive { get; set; }
        public DateTime CreatedAt { get; set; }
        public DateTime? LastLoginAt { get; set; }
        public string Role { get; set; } = "";
        public bool IsSelf => false; // Would compare against current user ID
    }
}
