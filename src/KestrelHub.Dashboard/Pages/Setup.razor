@page "/setup"
@using System.Net.Http.Json
@using System.Text.Json
@using KestrelHub.Dashboard.Services
@inject HttpClient Http
@inject NavigationManager Navigation
@inject JwtAuthStateProvider AuthStateProvider

<PageTitle>Setup — KestrelHub</PageTitle>

<div class="auth-container">
    <div class="auth-card">
        <div class="auth-header">
            <MudText Typo="Typo.h5" Style="color: var(--kh-text-primary);">Welcome to KestrelHub</MudText>
            <MudText Typo="Typo.body2" Style="color: var(--kh-text-secondary); margin-top: 4px;">
                Create your admin account to get started.
            </MudText>
        </div>

        @if (!string.IsNullOrEmpty(_error))
        {
            <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Dense="true" Class="mb-4">
                @_error
            </MudAlert>
        }

        <MudTextField @bind-Value="_displayName" Label="Display Name" Variant="Variant.Outlined"
                      Margin="Margin.Dense" />
        <MudTextField @bind-Value="_email" Label="Email" Variant="Variant.Outlined"
                      InputType="InputType.Email" Margin="Margin.Dense" Class="mt-3" />
        <MudTextField @bind-Value="_password" Label="Password" Variant="Variant.Outlined"
                      InputType="@(_showPw ? InputType.Text : InputType.Password)"
                      Margin="Margin.Dense" Class="mt-3"
                      OnKeyUp="@(_ => StateHasChanged())"
                      Adornment="Adornment.End"
                      AdornmentIcon="@(_showPw ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                      OnAdornmentClick="@(() => _showPw = !_showPw)" />
        <MudTextField @bind-Value="_confirmPassword" Label="Confirm Password" Variant="Variant.Outlined"
                      InputType="@(_showPw ? InputType.Text : InputType.Password)"
                      Margin="Margin.Dense" Class="mt-3" />

        <div class="strength-indicator">
            <div class="strength-bar">
                <div class="strength-fill @StrengthClass" style="width: @StrengthPercent%"></div>
            </div>
            <MudText Typo="Typo.caption" Style="color: var(--kh-text-secondary);">
                @StrengthLabel
            </MudText>
        </div>

        <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                   OnClick="@HandleSetupAsync" Disabled="@_loading" Class="mt-4"
                   Style="height: 42px;">
            @if (_loading)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" />
            }
            else
            {
                <span>Create Admin Account</span>
            }
        </MudButton>
    </div>
</div>

@code {
    private string _displayName = "";
    private string _email = "";
    private string _password = "";
    private string _confirmPassword = "";
    private string? _error;
    private bool _loading;
    private bool _showPw;
    private bool _setupComplete;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var response = await Http.GetFromJsonAsync<JsonElement>("/api/setup/status");
            _setupComplete = response.GetProperty("isSetupComplete").GetBoolean();

            if (_setupComplete)
            {
                Navigation.NavigateTo("/login");
            }
        }
        catch
        {
            // API unreachable
        }
    }

    private async Task HandleSetupAsync()
    {
        _error = null;

        if (_password != _confirmPassword)
        {
            _error = "Passwords do not match.";
            return;
        }

        if (_password.Length < 12)
        {
            _error = "Password must be at least 12 characters.";
            return;
        }

        _loading = true;

        try
        {
            var response = await Http.PostAsJsonAsync("/api/setup/complete", new
            {
                AdminEmail = _email,
                AdminPassword = _password,
                AdminDisplayName = _displayName
            });

            if (response.IsSuccessStatusCode)
            {
                var body = await response.Content.ReadFromJsonAsync<JsonElement>();
                Navigation.NavigateTo("/login");
            }
            else
            {
                var body = await response.Content.ReadAsStringAsync();
                _error = "Setup failed. Please check your inputs.";
            }
        }
        catch
        {
            _error = "Could not connect to server.";
        }

        _loading = false;
    }

    private int PasswordStrength
    {
        get
        {
            int score = 0;
            if (_password.Length >= 8) score++;
            if (_password.Length >= 12) score++;
            if (_password.Any(char.IsUpper)) score++;
            if (_password.Any(char.IsLower)) score++;
            if (_password.Any(char.IsDigit)) score++;
            if (_password.Any(c => !char.IsLetterOrDigit(c))) score++;
            return score;
        }
    }

    private int StrengthPercent => (int)((PasswordStrength / 6.0) * 100);

    private string StrengthClass => PasswordStrength switch
    {
        <= 2 => "weak",
        <= 4 => "medium",
        _ => "strong"
    };

    private string StrengthLabel => PasswordStrength switch
    {
        <= 2 => "Weak",
        <= 4 => "Medium",
        _ => "Strong"
    };
}
