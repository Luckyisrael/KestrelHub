@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Authorization
@using KestrelHub.Dashboard.Services
@inject JwtAuthStateProvider AuthStateProvider
@inject NavigationManager Navigation

<MudThemeProvider Theme="_theme" />
<MudDialogProvider />
<MudSnackbarProvider />

@if (_isAuthenticated)
{
    <div class="kh-shell">
        <aside class="kh-sidebar">
            <div class="kh-sidebar-header">
                <MudText Typo="Typo.h6" Style="color: #00d4ff; font-weight: 700; letter-spacing: 0.5px;">
                    KestrelHub
                </MudText>
            </div>
            <nav class="kh-nav">
                <a href="/deployments" class="kh-nav-item @ActiveClass("/deployments")">
                    <MudIcon Icon="@Icons.Material.Filled.CloudQueue" Size="Size.Small" />
                    <span>Deployments</span>
                </a>
                <a href="/secrets" class="kh-nav-item @ActiveClass("/secrets")">
                    <MudIcon Icon="@Icons.Material.Filled.Key" Size="Size.Small" />
                    <span>Secrets</span>
                </a>
                <a href="/storage" class="kh-nav-item @ActiveClass("/storage")">
                    <MudIcon Icon="@Icons.Material.Filled.Storage" Size="Size.Small" />
                    <span>Storage</span>
                </a>
                <a href="/observability" class="kh-nav-item @ActiveClass("/observability")">
                    <MudIcon Icon="@Icons.Material.Filled.MonitorHeart" Size="Size.Small" />
                    <span>Observability</span>
                </a>
                <AuthorizeView Roles="Admin">
                    <Authorized>
                        <a href="/settings" class="kh-nav-item @ActiveClass("/settings")">
                            <MudIcon Icon="@Icons.Material.Filled.Settings" Size="Size.Small" />
                            <span>Settings</span>
                        </a>
                    </Authorized>
                </AuthorizeView>
            </nav>
            <div class="kh-sidebar-footer">
                <a href="/logout" class="kh-nav-item">
                    <MudIcon Icon="@Icons.Material.Filled.Logout" Size="Size.Small" />
                    <span>Logout</span>
                </a>
            </div>
        </aside>
        <main class="kh-main">
            <header class="kh-topbar">
                <MudText Typo="Typo.body2" Style="color: #8a8d93;">
                    @_displayName
                </MudText>
            </header>
            <div class="kh-content">
                @Body
            </div>
        </main>
    </div>
}
else
{
    <div class="kh-auth-wrapper">
        @Body
    </div>
}

@code {
    private bool _isAuthenticated;
    private string _displayName = "";

    private MudTheme _theme = new()
    {
        PaletteDark = new PaletteDark()
        {
            Primary = "#00d4ff",
            Secondary = "#7c3aed",
            Background = "#0a0c0f",
            Surface = "#12141a",
            AppbarBackground = "#0d0f13",
            DrawerBackground = "#0d0f13",
            TextPrimary = "#e4e6eb",
            TextSecondary = "#8a8d93",
            ActionDefault = "#8a8d93",
            Divider = "#1e2028",
            TableLines = "#1e2028",
            LinesDefault = "#1e2028"
        }
    };

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        _isAuthenticated = state.User.Identity?.IsAuthenticated == true;
        _displayName = state.User.FindFirst("unique_name")?.Value
            ?? state.User.FindFirst(System.Security.Claims.ClaimTypes.Name)?.Value
            ?? "";
    }

    private string ActiveClass(string path)
    {
        var current = Navigation.ToBaseRelativePath(Navigation.Uri).TrimEnd('/');
        return current.StartsWith(path.TrimStart('/')) ? "active" : "";
    }
}
